# OpenBrainFun runtime configuration.
#
# Copy this file to .env for a permanent local installation:
#   scripts/init-env.sh
#
# This file configures the application runtime. Do not store user login
# passwords or MCP bearer tokens here; provision those with the `openbrain`
# CLI so they are stored hashed in the database.

OPENBRAIN_WEB_ADDR=127.0.0.1:18080
OPENBRAIN_MCP_ADDR=127.0.0.1:18081

OPENBRAIN_POSTGRES_CONTAINER_NAME=openbrain-postgres
OPENBRAIN_POSTGRES_IMAGE=pgvector/pgvector:pg16
OPENBRAIN_POSTGRES_HOST_PORT=5432
OPENBRAIN_POSTGRES_DB=openbrain
OPENBRAIN_POSTGRES_USER=openbrain
OPENBRAIN_POSTGRES_PASSWORD=__GENERATE_POSTGRES_PASSWORD__
OPENBRAIN_POSTGRES_VOLUME_NAME=openbrain-postgres-data
OPENBRAIN_POSTGRES_PGDATA=/var/lib/postgresql/data/pgdata
OPENBRAIN_POSTGRES_READY_TIMEOUT_SECONDS=30

# Leave OPENBRAIN_POSTGRES_DATA_DIR unset to use a container-managed named
# volume, which is the safer default for macOS `container`.
# OPENBRAIN_POSTGRES_DATA_DIR=/absolute/path/to/postgres-data

OPENBRAIN_OLLAMA_URL=http://127.0.0.1:11434
OPENBRAIN_EMBED_MODEL=all-minilm:22m
OPENBRAIN_METADATA_MODEL=qwen3:0.6b

OPENBRAIN_SESSION_TTL=24h

# Use true for permanent HTTPS deployments behind a reverse proxy.
OPENBRAIN_COOKIE_SECURE=true
OPENBRAIN_CSRF_KEY=__GENERATE_CSRF_KEY__

OPENBRAIN_LOG_LEVEL=info
